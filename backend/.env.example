# Optional. If omitted, the backend checks PATH and common macOS/Homebrew locations.
STOCKFISH_PATH=

# Lower is faster. Raise for stronger analysis.
ENGINE_DEPTH=12

# Comma-separated frontend origins allowed to call the API in production.
ALLOWED_ORIGINS=http://localhost:3000

# Optional regex for preview deployments. Defaults to localhost and *.vercel.app.
ALLOWED_ORIGIN_REGEX=
